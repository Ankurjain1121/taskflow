#!/bin/sh
# =============================================================================
# TaskFlow - Pre-Commit Hook
# =============================================================================
# Runs fast checks on staged files before every commit.
# Blocks commit if critical issues found.
#
# Setup: git config core.hooksPath .githooks
#    or: ./scripts/setup-hooks.sh
#
# Skip:  git commit --no-verify  (emergencies only)
# =============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

ERRORS=0
WARNINGS=0

echo ""
echo "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo "${BLUE}  Pre-Commit Checks${NC}"
echo "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
    echo "${GREEN}  No staged files. Skipping checks.${NC}"
    exit 0
fi

# Separate by type
STAGED_RS=$(echo "$STAGED_FILES" | grep '\.rs$' || true)
STAGED_TS=$(echo "$STAGED_FILES" | grep '\.ts$' || true)
STAGED_HTML=$(echo "$STAGED_FILES" | grep '\.html$' || true)
STAGED_SQL=$(echo "$STAGED_FILES" | grep '\.sql$' || true)
STAGED_ALL="$STAGED_FILES"

# =========================================================================
# Check 1: Hardcoded Secrets
# =========================================================================
echo ""
echo "${BLUE}  [1/7] Scanning for hardcoded secrets...${NC}"

SECRET_PATTERNS='(password|secret|api_key|apikey|token|private_key)\s*=\s*["\x27][^"\x27]{8,}'
FOUND_SECRETS=0

for file in $STAGED_ALL; do
    # Skip binary files, lock files, and config samples
    case "$file" in
        *.lock|*.png|*.jpg|*.ico|*.woff*|*.env.example|*.env.production) continue ;;
    esac

    if [ -f "$file" ]; then
        MATCHES=$(git diff --cached -- "$file" | grep '^+' | grep -v '^+++' | grep -iE "$SECRET_PATTERNS" || true)
        if [ -n "$MATCHES" ]; then
            echo "    ${RED}BLOCKED${NC} Possible secret in: $file"
            echo "$MATCHES" | head -3 | sed 's/^/      /'
            FOUND_SECRETS=1
        fi
    fi
done

if [ "$FOUND_SECRETS" -eq 1 ]; then
    ERRORS=$((ERRORS + 1))
    echo "    ${RED}Use environment variables instead of hardcoded secrets!${NC}"
else
    echo "    ${GREEN}OK${NC} No secrets detected"
fi

# =========================================================================
# Check 2: console.log / debugger in TypeScript
# =========================================================================
echo ""
echo "${BLUE}  [2/7] Checking for debug statements...${NC}"

FOUND_DEBUG=0

for file in $STAGED_TS; do
    if [ -f "$file" ]; then
        # Only check added lines (not removed)
        ADDED_LINES=$(git diff --cached -- "$file" | grep '^+' | grep -v '^+++' || true)

        CONSOLE_LOGS=$(echo "$ADDED_LINES" | grep -n 'console\.\(log\|debug\|info\|warn\)(' || true)
        DEBUGGERS=$(echo "$ADDED_LINES" | grep -n 'debugger' || true)

        if [ -n "$CONSOLE_LOGS" ]; then
            echo "    ${YELLOW}WARN${NC} console.log in: $file"
            FOUND_DEBUG=1
        fi
        if [ -n "$DEBUGGERS" ]; then
            echo "    ${RED}BLOCKED${NC} debugger statement in: $file"
            ERRORS=$((ERRORS + 1))
        fi
    fi
done

if [ "$FOUND_DEBUG" -eq 1 ]; then
    WARNINGS=$((WARNINGS + 1))
    echo "    ${YELLOW}Tip: Remove console.log before production${NC}"
elif [ -z "$STAGED_TS" ]; then
    echo "    ${GREEN}OK${NC} No TypeScript files staged"
else
    echo "    ${GREEN}OK${NC} No debug statements found"
fi

# =========================================================================
# Check 3: TypeScript Compilation (frontend)
# =========================================================================
echo ""
echo "${BLUE}  [3/7] TypeScript type-check...${NC}"

if [ -n "$STAGED_TS" ] || [ -n "$STAGED_HTML" ]; then
    FRONTEND_FILES=$(echo "$STAGED_TS $STAGED_HTML" | tr ' ' '\n' | grep '^frontend/' || true)

    if [ -n "$FRONTEND_FILES" ]; then
        # Run tsc --noEmit from frontend directory
        if (cd frontend && npx tsc --noEmit --project tsconfig.app.json 2>&1); then
            echo "    ${GREEN}OK${NC} TypeScript compiles cleanly"
        else
            echo "    ${RED}BLOCKED${NC} TypeScript compilation errors found"
            ERRORS=$((ERRORS + 1))
        fi
    else
        echo "    ${GREEN}OK${NC} No frontend files changed"
    fi
else
    echo "    ${GREEN}OK${NC} No TypeScript/HTML files staged"
fi

# =========================================================================
# Check 4: Rust syntax check (only staged .rs files, quick validation)
# =========================================================================
echo ""
echo "${BLUE}  [4/7] Rust file validation...${NC}"

if [ -n "$STAGED_RS" ]; then
    RUST_ISSUES=0

    for file in $STAGED_RS; do
        if [ -f "$file" ]; then
            ADDED=$(git diff --cached -- "$file" | grep '^+' | grep -v '^+++' || true)

            # Check for unwrap() in non-test code
            if echo "$file" | grep -v 'test' > /dev/null; then
                UNWRAPS=$(echo "$ADDED" | grep '\.unwrap()' || true)
                if [ -n "$UNWRAPS" ]; then
                    echo "    ${YELLOW}WARN${NC} .unwrap() found in: $file"
                    echo "    ${YELLOW}     Consider using ? or .expect() with a message${NC}"
                    WARNINGS=$((WARNINGS + 1))
                fi
            fi

            # Check for todo!() / unimplemented!()
            TODOS=$(echo "$ADDED" | grep -E '(todo!|unimplemented!|panic!)' || true)
            if [ -n "$TODOS" ]; then
                echo "    ${YELLOW}WARN${NC} todo!/unimplemented!/panic! in: $file"
                WARNINGS=$((WARNINGS + 1))
            fi

            # Check for println! (should use tracing instead)
            PRINTLNS=$(echo "$ADDED" | grep 'println!' || true)
            if [ -n "$PRINTLNS" ]; then
                echo "    ${YELLOW}WARN${NC} println! in: $file (use tracing::info! instead)"
                WARNINGS=$((WARNINGS + 1))
            fi
        fi
    done

    if [ "$RUST_ISSUES" -eq 0 ] && [ "$WARNINGS" -eq 0 ]; then
        echo "    ${GREEN}OK${NC} Rust files look clean"
    fi
else
    echo "    ${GREEN}OK${NC} No Rust files staged"
fi

# =========================================================================
# Check 5: SQL migration safety
# =========================================================================
echo ""
echo "${BLUE}  [5/7] SQL migration safety...${NC}"

if [ -n "$STAGED_SQL" ]; then
    SQL_ISSUES=0

    for file in $STAGED_SQL; do
        if [ -f "$file" ]; then
            # Check for destructive operations without IF EXISTS
            if grep -qiP '^\s*DROP\s+(TABLE|INDEX|COLUMN)' "$file"; then
                if ! grep -qi 'IF EXISTS' "$file"; then
                    echo "    ${YELLOW}WARN${NC} DROP without IF EXISTS in: $file"
                    WARNINGS=$((WARNINGS + 1))
                fi
            fi

            # Check for TRUNCATE
            if grep -qi 'TRUNCATE' "$file"; then
                echo "    ${RED}BLOCKED${NC} TRUNCATE in migration: $file"
                ERRORS=$((ERRORS + 1))
            fi

            # Check for DELETE without WHERE
            if grep -qiP '^\s*DELETE\s+FROM\s+\w+\s*;' "$file"; then
                echo "    ${RED}BLOCKED${NC} DELETE without WHERE in: $file"
                ERRORS=$((ERRORS + 1))
            fi
        fi
    done

    if [ "$SQL_ISSUES" -eq 0 ] && [ "$ERRORS" -eq 0 ]; then
        echo "    ${GREEN}OK${NC} SQL migrations look safe"
    fi
else
    echo "    ${GREEN}OK${NC} No SQL files staged"
fi

# =========================================================================
# Check 6: Large file detection
# =========================================================================
echo ""
echo "${BLUE}  [6/7] Large file check...${NC}"

LARGE_FILES=0
for file in $STAGED_ALL; do
    if [ -f "$file" ]; then
        SIZE=$(wc -c < "$file" 2>/dev/null || echo 0)
        # Block files > 1MB
        if [ "$SIZE" -gt 1048576 ]; then
            echo "    ${RED}BLOCKED${NC} File too large ($(( SIZE / 1024 ))KB): $file"
            ERRORS=$((ERRORS + 1))
            LARGE_FILES=1
        # Warn files > 500KB
        elif [ "$SIZE" -gt 524288 ]; then
            echo "    ${YELLOW}WARN${NC} Large file ($(( SIZE / 1024 ))KB): $file"
            WARNINGS=$((WARNINGS + 1))
        fi
    fi
done

if [ "$LARGE_FILES" -eq 0 ]; then
    echo "    ${GREEN}OK${NC} No oversized files"
fi

# =========================================================================
# Check 7: Auth file change detection (warning only)
# =========================================================================
echo ""
echo "${BLUE}  [7/7] Auth file change detection...${NC}"

AUTH_FILES=$(echo "$STAGED_ALL" | grep -E '(auth\.service|auth\.guard|auth\.interceptor|auth-initializer|sign-in\.component|sign-up\.component|auth\.rs)' || true)

if [ -n "$AUTH_FILES" ]; then
    WARNINGS=$((WARNINGS + 1))
    echo "    ${YELLOW}WARN${NC} Auth-related files modified:"
    echo "$AUTH_FILES" | sed 's/^/      /'
    echo "    ${YELLOW}Reminder: Run auth smoke test after deploy:${NC}"
    echo "    ${YELLOW}  ./scripts/smoke-test-auth.sh https://taskflow.paraslace.in${NC}"
else
    echo "    ${GREEN}OK${NC} No auth files changed"
fi

# =========================================================================
# Summary
# =========================================================================
echo ""
echo "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

if [ "$ERRORS" -gt 0 ]; then
    echo "${RED}  COMMIT BLOCKED — $ERRORS error(s), $WARNINGS warning(s)${NC}"
    echo "${RED}  Fix errors above, then try again.${NC}"
    echo "${YELLOW}  Emergency skip: git commit --no-verify${NC}"
    echo "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    exit 1
elif [ "$WARNINGS" -gt 0 ]; then
    echo "${YELLOW}  PASSED with $WARNINGS warning(s) — committing anyway${NC}"
    echo "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    exit 0
else
    echo "${GREEN}  ALL CHECKS PASSED${NC}"
    echo "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    exit 0
fi

# =============================================================================
# Check 8: Hardcoded Tailwind colors in frontend (WARNING)
# =============================================================================
# Theme system uses CSS variables. Hardcoded colors break across themes.
FRONTEND_STAGED=$(echo "$STAGED_FILES" | grep -E 'frontend/src/.*\.(ts|html)$' | grep -v '.spec.')
if [ -n "$FRONTEND_STAGED" ]; then
    HARDCODED=$(echo "$FRONTEND_STAGED" | xargs grep -n 'text-gray-\|bg-gray-\|border-gray-\|text-red-[0-9]\|text-blue-[0-9]\|text-green-[0-9]\|text-orange-[0-9]\|text-purple-[0-9]\|dark:text-\|dark:bg-\|dark:border-' 2>/dev/null | grep -v 'task-colors.ts' | head -10)
    if [ -n "$HARDCODED" ]; then
        echo ""
        echo "${YELLOW}  ⚠ HARDCODED COLORS DETECTED${NC}"
        echo "${YELLOW}  Use CSS variables instead (var(--foreground), var(--muted-foreground), etc.)${NC}"
        echo "$HARDCODED" | head -5
        WARNINGS=$((WARNINGS + 1))
    fi
fi
