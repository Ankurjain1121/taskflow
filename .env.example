# TaskBolt Environment Variables
# Copy to .env and fill in real values: cp .env.example .env

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=taskbolt

# Auth (REQUIRED - must be 32+ chars, no defaults)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# MinIO (S3-compatible storage)
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=task-attachments
MINIO_PUBLIC_URL=https://files.paraslace.in

# App
APP_URL=https://taskflow.paraslace.in
RUST_LOG=info,sqlx=warn,tower_http=debug

# Cron
CRON_SECRET=CHANGE_ME

# Lago Billing (required if using billing profile)
LAGO_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64

# Novu Notifications (required if using notifications profile)
NOVU_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# WAHA WhatsApp (required if using whatsapp profile)
WAHA_DASHBOARD_USER=CHANGE_ME
WAHA_DASHBOARD_PASSWORD=CHANGE_ME
