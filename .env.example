# =============================================================================
# TaskFlow - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment
#
# SECURITY: Never commit .env to version control!
# =============================================================================

# =============================================================================
# DATABASE - PostgreSQL
# =============================================================================
# Primary database for TaskFlow application
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taskflow
POSTGRES_PORT=5432

# Connection URLs (constructed from above, update host for local dev)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}
APP_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# Lago billing database (separate database on same PostgreSQL instance)
LAGO_DB=lago

# =============================================================================
# REDIS - Caching, Sessions, Pub/Sub
# =============================================================================
# Database isolation:
#   db0 = Application (sessions, cache, WebSocket pub/sub)
#   db1 = Lago (billing system)
#   db2 = Novu (notifications)
#
# The application connects to db0 by default via REDIS_URL
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# MONGODB - Novu Notifications
# =============================================================================
# MongoDB is used exclusively by Novu for notification storage
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin
MONGO_DB=novu
MONGO_PORT=27017

# =============================================================================
# AUTH - JWT Configuration
# =============================================================================
# IMPORTANT: Change these secrets in production!
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production-minimum-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me-in-production-minimum-32-chars
JWT_ACCESS_EXPIRY_SECS=900
JWT_REFRESH_EXPIRY_SECS=604800

# =============================================================================
# MINIO - S3-Compatible Object Storage
# =============================================================================
# Used for task attachments, avatars, and file storage
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=task-attachments
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Internal endpoint (for backend service)
MINIO_ENDPOINT=http://localhost:9000
# Public endpoint (for frontend direct uploads, change in production)
MINIO_PUBLIC_URL=http://localhost:9000

# =============================================================================
# LAGO - Billing & Metering (Optional)
# =============================================================================
# Lago provides usage-based billing and subscription management
# Enable with: docker compose --profile billing up -d
LAGO_API_PORT=3000
LAGO_FRONT_PORT=8085
LAGO_API_URL=http://localhost:3000
LAGO_API_KEY=

# Lago internal configuration
LAGO_SECRET_KEY=your-lago-secret-key-base-must-be-at-least-64-characters-long-change-in-production
LAGO_RSA_PRIVATE_KEY=
LAGO_DISABLE_SIGNUP=false
LAGO_FROM_EMAIL=noreply@taskflow.local

# =============================================================================
# NOVU - Notifications Infrastructure (Optional)
# =============================================================================
# Novu handles email, push, SMS, and in-app notifications
# Enable with: docker compose --profile notifications up -d
NOVU_API_PORT=3001
NOVU_API_URL=http://localhost:3001
NOVU_API_KEY=
NOVU_JWT_SECRET=your-novu-jwt-secret-change-in-production

# =============================================================================
# POSTAL - Email Server (Optional)
# =============================================================================
# Postal provides self-hosted email sending
# Enable with: docker compose --profile email up -d
POSTAL_HOSTNAME=postal.localhost
POSTAL_SMTP_HOSTNAME=smtp.localhost
POSTAL_WEB_PORT=8086
POSTAL_SMTP_PORT=25
POSTAL_SMTP_HOST=localhost

# =============================================================================
# WAHA - WhatsApp HTTP API (Optional)
# =============================================================================
# WAHA enables WhatsApp messaging integration
# Enable with: docker compose --profile whatsapp up -d
WAHA_PORT=3002
WAHA_API_URL=http://localhost:3002
WAHA_API_KEY=
WAHA_DASHBOARD_USER=admin
WAHA_DASHBOARD_PASSWORD=admin

# =============================================================================
# STRIPE - Payment Processing (Optional)
# =============================================================================
# Stripe integration for payment processing (used alongside Lago)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# CRON - Scheduled Tasks
# =============================================================================
# Cron job configuration for background tasks
CRON_ENABLED=true
CRON_TIMEZONE=UTC

# =============================================================================
# APPLICATION
# =============================================================================
# Server configuration
HOST=0.0.0.0
PORT=8080
BACKEND_PORT=8080
FRONTEND_PORT=80

# Logging
RUST_LOG=info,sqlx=warn,tower_http=debug

# Frontend URL (for CORS and email links)
APP_URL=http://localhost:4200

# Skip initialization on startup (set to true after first run)
SKIP_INIT=false
SKIP_SEED=false

# =============================================================================
# REVERSE PROXY NOTES
# =============================================================================
# When running behind a reverse proxy (nginx, Traefik, etc.):
#
# 1. Update APP_URL to your production domain
# 2. Update MINIO_PUBLIC_URL to your S3 endpoint
# 3. Configure SSL termination at the proxy level
# 4. Set proper CORS headers for cross-origin requests
#
# Example nginx location blocks:
#
#   location /api/ {
#       proxy_pass http://backend:8080/api/;
#       proxy_http_version 1.1;
#       proxy_set_header Upgrade $http_upgrade;
#       proxy_set_header Connection "upgrade";
#   }
#
#   location /ws {
#       proxy_pass http://backend:8080/ws;
#       proxy_http_version 1.1;
#       proxy_set_header Upgrade $http_upgrade;
#       proxy_set_header Connection "upgrade";
#   }
# =============================================================================
