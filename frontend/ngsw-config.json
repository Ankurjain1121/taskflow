{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-general",
      "urls": [
        "/api/projects/**",
        "/api/workspaces/**",
        "/api/tasks/**",
        "/api/boards/**",
        "/api/dashboard/**",
        "/api/reports/**",
        "/api/search/**",
        "/api/members/**",
        "/api/labels/**",
        "/api/columns/**",
        "/api/my-tasks/**",
        "/api/eisenhower/**",
        "/api/favorites/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 200,
        "maxAge": "1d",
        "timeout": "5s"
      }
    },
    {
      "name": "api-user",
      "urls": [
        "/api/me/**",
        "/api/notifications/**",
        "/api/user-preferences/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "1d",
        "timeout": "5s"
      }
    },
    {
      "name": "google-fonts",
      "urls": [
        "https://fonts.googleapis.com/**",
        "https://fonts.gstatic.com/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 50,
        "maxAge": "30d"
      }
    }
  ]
}
