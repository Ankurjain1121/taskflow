# =============================================================================
# TaskFlow - Caddy Configuration
# =============================================================================
# Domain: taskflow.paraslace.in
# Automatic HTTPS with Let's Encrypt
# =============================================================================

taskflow.paraslace.in {
    # API endpoints
    handle /api/* {
        reverse_proxy backend:8080
    }

    # WebSocket endpoint
    handle /ws {
        reverse_proxy backend:8080
    }

    # Health check endpoint
    handle /health {
        reverse_proxy backend:8080
    }

    # Frontend - Angular SPA (default handler)
    handle {
        reverse_proxy frontend:80
    }

    # Logging
    log {
        output stdout
        format console
    }

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        X-XSS-Protection "1; mode=block"
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # Enable compression
    encode gzip zstd
}

# MinIO / S3 endpoint (for file uploads)
files.paraslace.in {
    reverse_proxy minio:9000

    header {
        Access-Control-Allow-Origin https://taskflow.paraslace.in
        Access-Control-Allow-Methods "GET, HEAD, PUT, POST, DELETE"
        Access-Control-Allow-Headers "*"
    }

    encode gzip zstd
}

# MinIO Console (admin access)
minio.paraslace.in {
    reverse_proxy minio:9001
}
