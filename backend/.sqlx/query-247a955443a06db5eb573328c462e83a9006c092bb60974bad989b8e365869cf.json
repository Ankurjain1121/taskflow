{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            c.id,\n            c.content,\n            c.task_id,\n            c.author_id,\n            c.parent_id,\n            c.mentioned_user_ids,\n            c.created_at,\n            c.updated_at,\n            u.name as author_name,\n            u.avatar_url as author_avatar_url\n        FROM comments c\n        JOIN users u ON u.id = c.author_id\n        WHERE c.task_id = $1 AND c.deleted_at IS NULL\n        ORDER BY c.created_at ASC\n        ",
