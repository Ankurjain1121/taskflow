  "query": "\n        UPDATE project_statuses\n        SET\n          name     = COALESCE($2, name),\n          color    = COALESCE($3, color),\n          type     = COALESCE($4, type)\n        WHERE id = $1\n        RETURNING id, project_id, name, color,\n                  type as \"status_type\",\n                  position, is_default, tenant_id, created_at,\n                  allowed_transitions\n        ",
