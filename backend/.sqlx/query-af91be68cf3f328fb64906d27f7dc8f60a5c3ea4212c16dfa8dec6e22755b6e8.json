{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT wm.user_id, u.name, u.email, u.avatar_url, wm.joined_at\n                FROM workspace_members wm\n                INNER JOIN users u ON wm.user_id = u.id\n                WHERE wm.workspace_id = $1\n                  AND u.deleted_at IS NULL\n                ORDER BY wm.joined_at ASC\n                ",
