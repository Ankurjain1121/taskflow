  "query": "\n        INSERT INTO project_members (project_id, user_id, role)\n        VALUES ($1, $2, $3)\n        ON CONFLICT (project_id, user_id) DO UPDATE SET role = $3\n        RETURNING id, project_id, user_id, role AS \"role: _\", joined_at\n        ",
