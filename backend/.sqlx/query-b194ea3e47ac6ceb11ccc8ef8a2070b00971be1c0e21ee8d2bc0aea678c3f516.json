{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            id,\n            email,\n            name,\n            avatar_url,\n            role as \"role: UserRole\",\n            onboarding_completed,\n            created_at\n        FROM users\n        WHERE tenant_id = $1\n          AND deleted_at IS NULL\n          AND ($2::text IS NULL OR name ILIKE '%' || $2 || '%' OR email ILIKE '%' || $2 || '%')\n          AND ($3::user_role IS NULL OR role = $3)\n        ORDER BY created_at DESC\n        ",
