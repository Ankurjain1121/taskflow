  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, recipient_id, event_type, title, body, link_url, is_read, archived_at, created_at\n            FROM notifications\n            WHERE recipient_id = $1\n              AND archived_at IS NULL\n            ORDER BY created_at DESC, id DESC\n            LIMIT $2\n            ",
